# Fitbod refresh-token JWT. Capture once via mitmproxy by signing into the
# Android app — the token comes back in the `Authorization` header of the
# 201 response from POST gate-keeper.fitbod.me/users/login. Token expiry is
# ~1 year, so re-capture annually. Do NOT commit real values.
FITBOD_REFRESH_TOKEN=

# Polling cadence (Go duration string, minimum 5m enforced in code).
POLL_INTERVAL=15m

# HTTP server for stats.json (LAN-only — no auth).
HTTP_PORT=8090

# HTTP User-Agent. Default mimics the real Fitbod Android client; honest
# custom strings get blocked by Cloudflare's WAF on every fitbod.me host.
# See sync/fitbodapi/client.go for why.
USER_AGENT=okhttp/5.3.2

# Path to the resource config (see classes.yaml.example).
CLASSES_FILE=classes.yaml
