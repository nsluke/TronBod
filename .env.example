# Fitbod Parse credentials — capture these via mitmproxy against the Android
# app. Do NOT commit real values.
FITBOD_APP_ID=
FITBOD_CLIENT_KEY=
FITBOD_BASE_URL=https://parse.fitbod.me

# Fitbod account
FITBOD_EMAIL=
FITBOD_PASSWORD=

# Polling cadence (Go duration string, minimum 5m enforced in code)
POLL_INTERVAL=15m

# HTTP server for stats.json (LAN-only — no auth)
HTTP_PORT=8090

# Used in the User-Agent header so Fitbod can reach you if they want to.
# Make this a real GitHub URL or contact email.
USER_AGENT_CONTACT=https://github.com/nsluke/TronBod

# Path to the class config (see classes.yaml.example)
CLASSES_FILE=classes.yaml
